<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Product Details - Our Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="index.html">Our Store</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
            {% if app.user %}
                <li class="nav-item">
                    <span class="nav-link text-white">Bienvenue, {{ app.user.name }}</span>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_logout') }}">Logout</a>
                </li>
            {% else %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('app_login') }}">Login</a>
                </li>
            {% endif %}
            </div>
        </div>
    </nav>

    <!-- Product Details Section -->
    <div class="container my-5">
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-6">
                <img src="airbod.png" class="img-fluid rounded" alt="Product">
            </div>

<!-- Product Information -->
<div class="col-md-6">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_browse_categories') }}" class="text-decoration-none">Home</a></li>
            <li class="breadcrumb-item active" aria-current="page">Product Details</li>
        </ol>
    </nav>

    <span class="badge bg-primary mb-3">{{ product.category.name }}</span>

    <h1 class="mb-3">{{ product.name }}</h1>

    <h3 class="text-success mb-4">${{ product.price }}</h3>

    <div class="mb-4">
        <h5>Description</h5>
        <p class="text-muted">{{ product.description }}</p>
    </div>

    <!-- Add to Cart Form -->
    {{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.quantity) }}
        {{ form_widget(form.quantity) }}
    </div>
    <div class="d-grid gap-2 d-md-flex">
        {{ form_widget(form.submit) }}
        <a href="{{ path('app_browse_categories') }}" class="btn btn-outline-secondary btn-lg">Continue Shopping</a>
    </div>
    {{ form_end(form) }}

    <!-- Additional Info -->
    <div class="mt-4 pt-4 border-top">
        <ul class="list-unstyled">
            <li class="mb-2"><strong>Availability:</strong> <span class="text-success">In Stock</span></li>
            <li class="mb-2"><strong>Category:</strong> {{ product.category.name }}</li>
        </ul>
    </div>
</div>
        </div>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>Our Store</h5>
                    <p>Quality products at affordable prices</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>&copy; 2026 Our Store. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
